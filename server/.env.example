# PostgreSQL — Supabase connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.YOUR_SUPABASE_URL.supabase.co:5432/postgres?sslmode=require

# AWS Bedrock Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
# data.gov.in Open Data API
DATA_GOV_API_KEY=your_data_gov_api_key_here


# Twilio API
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_API_KEY_SID=your_twilio_api_key_sid_here
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Server
PORT=5000
NODE_ENV=development

# CORS origin
CLIENT_URL=http://localhost:5173
